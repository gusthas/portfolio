# =============================================================================
# VARIÁVEIS DE AMBIENTE — COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES
# Nunca commite o .env — apenas o .env.example vai ao repositório
# =============================================================================

# --- BANCO DE DADOS ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/portfolio"

# --- REDIS (Cache) ---
REDIS_URL="redis://localhost:6379"

# --- GITHUB API ---
# Gere em: https://github.com/settings/tokens
# Permissões necessárias: repo (read), user (read)
GITHUB_TOKEN=""
GITHUB_USERNAME=""

# --- RAWG API (Jogos) ---
# Gere em: https://rawg.io/apidocs
RAWG_API_KEY=""

# --- GOOGLE BOOKS API ---
# Gere em: https://console.cloud.google.com/
GOOGLE_BOOKS_API_KEY=""

# --- BACKEND (NestJS) ---
API_PORT=3001
API_URL="http://localhost:3001"
NODE_ENV="development"

# --- FRONTEND (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- WEBHOOKS ---
# Secret para validar webhooks do GitHub (gere um hash aleatório)
WEBHOOK_SECRET=""

# --- JWT (autenticação admin) ---
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
